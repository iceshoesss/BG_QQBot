# NoneBot2 环境配置
# 复制为 .env 并填写实际值

# 需要 websockets 驱动支持反向 WebSocket 客户端
DRIVER=~fastapi+~websockets

# 联赛网站 API 地址
LEAGUE_API_URL=http://localhost:5000

# QQ 群号（联赛通知群）
LEAGUE_NOTIFY_GROUP_ID=

# 日志级别
LOG_LEVEL=DEBUG

# SuperUsers（管理员 QQ 号，逗号分隔）
SUPERUSERS=[""]

# 命令前缀（空字符串=无前缀也能触发）
COMMAND_START=["", "/"]

# OneBot 连接方式（反向 WebSocket）
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]
